{
  "name": "auto-server-client",
  "version": "0.3.0",
  "description": "A unified, secure data-access layer for Next.js App Router that eliminates the need to write individual Server Actions for every API request",
  "keywords": [
    "nextjs",
    "next.js",
    "app-router",
    "server-actions",
    "api-client",
    "react-hooks",
    "ssr",
    "typescript",
    "authentication",
    "proxy"
  ],
  "author": "Prabal Goyal",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/prabal-goyal/next-server-client.git"
  },
  "homepage": "https://github.com/prabal-goyal/next-server-client#readme",
  "bugs": {
    "url": "https://github.com/prabal-goyal/next-server-client/issues"
  },
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "lint": "eslint"
  },
  "peerDependencies": {
    "next": ">=14",
    "react": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20",
    "@types/react": "^19",
    "eslint": "^9",
    "tsup": "^8.5.1",
    "typescript": "^5",
    "typescript-eslint": "^8.58.1"
  }
}
